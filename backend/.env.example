# ─── Backend Environment Variables ───────────────────────────
# Copy this to .env and fill in values before running locally.
# On Render: add these via the "Environment" tab in your service settings.

# MongoDB Atlas connection string (or local MongoDB URI)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/musicplayer?retryWrites=true&w=majority

# Port — Render sets this automatically; override only for local dev
PORT=5000

# Your Vercel frontend URL (no trailing slash)
# Example: https://music-player.vercel.app
CORS_ORIGIN=https://your-app.vercel.app
